# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS (comma-separated allowed frontend origins) ───────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Frontend URL (used for GitHub OAuth redirect) ────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── AI Services ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
FIGMA_API_TOKEN=your_figma_api_token_here

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Project ID from Firebase Console → Project Settings
FIREBASE_PROJECT_ID=your-firebase-project-id

# Option A: Path to downloaded service account JSON file (local dev)
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# Option B: Paste the entire service account JSON as a single-line string (production/CI)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New
# Callback URL: http://localhost:5000/api/github/callback
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# ── Legacy JWT (can remove after full Firebase migration) ─────────────────────
JWT_SECRET=replace_with_random_secret_string
